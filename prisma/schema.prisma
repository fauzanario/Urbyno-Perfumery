// Prisma schema for Urbyno Perfumery E-commerce (Supabase Postgres)

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =========================
// ENUMS
// =========================

enum OrderStatus {
  UNPAID
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELED
  EXPIRED
}

enum VoucherType {
  PERCENT
  FIXED
}

// =========================
// CATALOG
// =========================

model Product {
  id           String           @id @default(uuid()) @db.Uuid
  slug         String           @unique @db.Text
  name         String           @db.Text
  description  String?          @db.Text
  isActive     Boolean          @default(true)
  thumbnailUrl String?          @db.Text
  images       String[]         @default([])

  createdAt    DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @db.Timestamptz(6)

  variants     ProductVariant[]
  orderItems   OrderItem[]

  @@map("products")
}

model ProductVariant {
  id         String    @id @default(uuid()) @db.Uuid
  productId  String    @db.Uuid
  sku        String?   @unique @db.Text
  variantName String   @db.Text
  price      Decimal   @db.Decimal(12, 2)
  originalPrice Decimal?  @db.Decimal(12, 2) 
  isSale        Boolean   @default(false)
  stock      Int
  weightGram Int
  isActive   Boolean   @default(true)

  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(6)

  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([productId])
  @@unique([productId, variantName])
  @@map("product_variants")
}

// =========================
// ORDERS (Guest Checkout)
// =========================

model Order {
  id            String      @id @default(uuid()) @db.Uuid
  orderCode     String      @unique @db.Text

  customerName  String      @db.Text
  customerPhone String      @db.Text
  customerEmail String?     @db.Text

  addressDetail String      @db.Text
  provinceId    Int
  provinceName  String      @db.Text
  cityId        Int
  cityName      String      @db.Text
  postalCode    String?     @db.Text

  courierCode   String      @db.Text
  courierService String     @db.Text
  shippingCost  Decimal     @db.Decimal(12, 2)
  shippingEtd   String?     @db.Text

  voucherId     String?     @db.Uuid
  voucherCode   String?     @db.Text
  discountAmount Decimal    @default(0) @db.Decimal(12, 2)

  subtotal      Decimal     @db.Decimal(12, 2)
  grandTotal    Decimal     @db.Decimal(12, 2)

  status        OrderStatus @default(UNPAID)

  createdAt     DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @db.Timestamptz(6)

  items         OrderItem[]
  payment       Payment?
  shipment      Shipment?
  voucher       Voucher?    @relation(fields: [voucherId], references: [id], onDelete: SetNull)
  redemption    VoucherRedemption?

  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id                  String   @id @default(uuid()) @db.Uuid
  orderId             String   @db.Uuid
  
  productId           String?  @db.Uuid
  variantId           String?  @db.Uuid

  productNameSnapshot String  @db.Text
  variantNameSnapshot String  @db.Text
  unitPriceSnapshot   Decimal @db.Decimal(12, 2)
  qty                 Int
  weightGramSnapshot  Int
  lineTotal           Decimal @db.Decimal(12, 2)

  createdAt           DateTime @default(now()) @db.Timestamptz(6)

  order               Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  product             Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant             ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@map("order_items")
}

// =========================
// PAYMENTS (Midtrans Snap)
// =========================

model Payment {
  id                String   @id @default(uuid()) @db.Uuid
  orderId           String   @unique @db.Uuid

  midtransOrderId   String   @unique @db.Text
  snapToken         String?  @db.Text

  transactionStatus String?  @db.Text
  paymentType       String?  @db.Text
  fraudStatus       String?  @db.Text

  grossAmount       Decimal  @db.Decimal(12, 2)
  rawNotification   Json?

  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @db.Timestamptz(6)

  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([transactionStatus])
  @@map("payments")
}

// =========================
// SHIPMENTS
// =========================

model Shipment {
  id             String   @id @default(uuid()) @db.Uuid
  orderId         String   @unique @db.Uuid

  courierCode     String   @db.Text
  trackingNumber  String?  @db.Text
  shippedAt       DateTime? @db.Timestamptz(6)
  deliveredAt     DateTime? @db.Timestamptz(6)
  notes           String?  @db.Text

  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("shipments")
}

// =========================
// VOUCHERS
// =========================

model Voucher {
  id           String       @id @default(uuid()) @db.Uuid
  code         String       @unique @db.Text
  name         String?      @db.Text
  description  String?      @db.Text

  type         VoucherType
  value        Decimal      @db.Decimal(12, 2)
  maxDiscount  Decimal?     @db.Decimal(12, 2)
  minPurchase  Decimal      @default(0) @db.Decimal(12, 2)

  quota        Int?
  usedCount    Int          @default(0)

  startsAt     DateTime?    @db.Timestamptz(6)
  endsAt       DateTime?    @db.Timestamptz(6)

  isActive     Boolean      @default(true)

  createdAt    DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @db.Timestamptz(6)

  orders       Order[]
  redemptions  VoucherRedemption[]

  @@index([isActive])
  @@index([startsAt])
  @@index([endsAt])
  @@map("vouchers")
}

model VoucherRedemption {
  id             String   @id @default(uuid()) @db.Uuid
  voucherId      String   @db.Uuid
  orderId        String   @unique @db.Uuid

  customerPhone  String   @db.Text
  customerEmail  String?  @db.Text
  discountAmount Decimal  @db.Decimal(12, 2)

  redeemedAt     DateTime @default(now()) @db.Timestamptz(6)

  voucher        Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([voucherId])
  @@index([redeemedAt])
  @@map("voucher_redemptions")
}

// =========================
// LANDING PAGE (CMS-lite)
// =========================

model LandingPage {
  id        String          @id @default(uuid()) @db.Uuid
  key       String          @unique @db.Text   // e.g. "home"
  title     String?         @db.Text
  isActive  Boolean         @default(true)

  updatedAt DateTime        @updatedAt @db.Timestamptz(6)

  sections  LandingSection[]

  @@map("landing_pages")
}

model LandingSection {
  id        String    @id @default(uuid()) @db.Uuid
  pageId    String    @db.Uuid

  type      String    @db.Text     // HERO, PROMO_GRID, FEATURED_PRODUCTS
  position  Int
  isActive  Boolean   @default(true)

  title     String?   @db.Text
  subtitle  String?   @db.Text
  imageUrl  String?   @db.Text
  ctaText   String?   @db.Text
  ctaLink   String?   @db.Text

  payload   Json?

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)

  page      LandingPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([type])
  @@index([position])
  @@map("landing_sections")
}
